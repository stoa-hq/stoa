{
  "mcpServers": {
    "stoa-store": {
      "type": "stdio",
      "command": "./stoa-store-mcp",
      "args": ["--stdio"],
      "env": {
        "STOA_MCP_API_URL": "${STOA_MCP_API_URL:-http://localhost:8080}",
        "STOA_MCP_API_KEY": "${STOA_MCP_API_KEY}"
      }
    },
    "stoa-admin": {
      "type": "stdio",
      "command": "./stoa-admin-mcp",
      "args": ["--stdio"],
      "env": {
        "STOA_MCP_API_URL": "${STOA_MCP_API_URL:-http://localhost:8080}",
        "STOA_MCP_API_KEY": "${STOA_MCP_API_KEY}"
      }
    }
  }
}
